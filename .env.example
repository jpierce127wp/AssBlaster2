# Process role: api | worker | both
PROCESS_ROLE=both

# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://taskmaster:taskmaster@localhost:5432/taskmaster

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Embedding provider: voyage | openai
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=pa-...
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSIONS=1536

# Clio OAuth2
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
CLIO_REDIRECT_URI=http://localhost:3000/api/v1/auth/clio/callback
CLIO_API_BASE=https://app.clio.com/api/v4

# Auth
API_KEY=dev-api-key

# Tenant
DEFAULT_TENANT_ID=default

# Security
CORS_ORIGIN=*
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
